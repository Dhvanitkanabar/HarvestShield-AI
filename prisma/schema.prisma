// ==================================================
// HarvestShield AI - Prisma Schema
// ==================================================
// This is the single source of truth for the database
// Run `npx prisma migrate dev` to apply changes
// ==================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------
// Enums
// --------------------------------------------------

enum Role {
  ADMIN
  FARMER
  FPO
  WAREHOUSE
  PROCESSOR
  MARKET
  DRIVER
}

enum CropCategory {
  VEGETABLE
  FRUIT
  GRAIN
  PULSES
  OILSEED
  OTHER
}

enum WarehouseType {
  NORMAL
  COLD_STORAGE
  CONTROLLED_ATMOSPHERE
}

enum MarketType {
  LOCAL
  APMC
  PRIVATE
}

enum QualityGrade {
  A
  B
  C
}

enum Unit {
  KG
  TON
  CRATE
}

enum BatchStatus {
  FRESH
  STORED
  IN_TRANSIT
  AT_MARKET
  PROCESSING
  SOLD
  SPOILED
  EXPIRED
}

enum MovementType {
  HARVEST
  STORAGE
  TRANSPORT
  MARKET
  PROCESSOR
  SOLD
  SPOILED
}

// Phase 4 Enums
enum RecommendationAction {
  SELL_NOW
  STORE
  MOVE_TO_COLD_STORAGE
  TRANSFER_TO_ANOTHER_WAREHOUSE
  SEND_TO_PROCESSOR
  MOVE_TO_MARKET
  PARTIAL_SELL
  PARTIAL_STORE
  URGENT_ACTION_REQUIRED
  DISCARD
}

enum RiskCategory {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// --------------------------------------------------
// Models
// --------------------------------------------------

/// Core user model supporting multi-role stakeholders
/// across the agricultural supply chain.
model User {
  id         String   @id @default(uuid())
  fullName   String   @map("full_name")
  email      String   @unique
  phone      String?
  password   String
  role       Role     @default(FARMER)
  language   String   @default("en")
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  farmer     Farmer?
  driver     Driver?

  @@map("users")
}

/// Farmer profile linked to a User
model Farmer {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  aadhaarNumber  String?  @unique @map("aadhaar_number")
  farmName       String?  @map("farm_name")
  farmSize       Float    @map("farm_size")
  soilType       String?  @map("soil_type")
  irrigationType String?  @map("irrigation_type")
  
  village        String
  taluka         String
  district       String
  state          String
  country        String   @default("India")
  
  latitude       Float?
  longitude      Float?
  
  fpoId          String?  @map("fpo_id")
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fpo            Fpo?     @relation(fields: [fpoId], references: [id], onDelete: SetNull)

  harvestBatches HarvestBatch[]

  @@map("farmers")
}

/// Farmer Producer Organization
model Fpo {
  id                 String   @id @default(uuid())
  name               String
  registrationNumber String   @unique @map("registration_number")
  contactPerson      String   @map("contact_person")
  phone              String
  email              String?
  address            String
  district           String
  state              String
  
  latitude           Float?
  longitude          Float?
  
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  farmers            Farmer[]
  harvestBatches     HarvestBatch[]

  @@map("fpos")
}

/// Crop Master Data
model Crop {
  id                    String       @id @default(uuid())
  cropName              String       @map("crop_name")
  category              CropCategory
  scientificName        String?      @map("scientific_name")
  
  averageShelfLife      Int?         @map("average_shelf_life") // in days
  
  idealTemperatureMin   Float?       @map("ideal_temperature_min")
  idealTemperatureMax   Float?       @map("ideal_temperature_max")
  idealHumidityMin      Float?       @map("ideal_humidity_min")
  idealHumidityMax      Float?       @map("ideal_humidity_max")
  
  storageRecommendation String?      @map("storage_recommendation")
  processingOptions     String?      @map("processing_options")
  
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  harvestBatches        HarvestBatch[]
  marketPriceHistories  MarketPriceHistory[]
  pricePredictions      PricePrediction[]
  marketDemands         MarketDemand[]

  @@map("crops")
}

/// Warehouse Entity
model Warehouse {
  id                   String        @id @default(uuid())
  warehouseName        String        @map("warehouse_name")
  warehouseType        WarehouseType @map("warehouse_type")
  ownerName            String        @map("owner_name")
  
  capacity             Float         // e.g. in Metric Tons
  availableCapacity    Float         @map("available_capacity")
  
  temperatureSupported Boolean       @default(false) @map("temperature_supported")
  humiditySupported    Boolean       @default(false) @map("humidity_supported")
  
  district             String
  state                String
  latitude             Float?
  longitude            Float?
  contactNumber        String        @map("contact_number")
  
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  inventories          Inventory[]

  @@map("warehouses")
}

/// Market (Mandi) Entity
model Market {
  id            String     @id @default(uuid())
  marketName    String     @map("market_name")
  marketType    MarketType @map("market_type")
  
  district      String
  state         String
  latitude      Float?
  longitude     Float?
  contactNumber String?    @map("contact_number")
  
  operatingDays String?    @map("operating_days") // e.g., "Mon-Sat"
  
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  marketPriceHistories  MarketPriceHistory[]
  pricePredictions      PricePrediction[]
  marketDemands         MarketDemand[]

  @@map("markets")
}

/// Food Processor Entity
model Processor {
  id              String   @id @default(uuid())
  companyName     String   @map("company_name")
  
  acceptedCrops   String[] @map("accepted_crops")
  processingType  String   @map("processing_type")
  capacityPerDay  Float    @map("capacity_per_day") // e.g. in Metric Tons
  
  district        String
  state           String
  latitude        Float?
  longitude       Float?
  contactPerson   String   @map("contact_person")
  phone           String
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("processors")
}

// --------------------------------------------------
// Phase 3: Harvest & Inventory Intelligence
// --------------------------------------------------

/// Unique trackable inventory batch for harvested produce
model HarvestBatch {
  id                    String        @id @default(uuid())
  batchNumber           String        @unique @map("batch_number")
  
  farmerId              String        @map("farmer_id")
  cropId                String        @map("crop_id")
  fpoId                 String?       @map("fpo_id")
  
  quantity              Float
  unit                  Unit          @default(KG)
  qualityGrade          QualityGrade  @map("quality_grade")
  
  harvestDate           DateTime      @map("harvest_date")
  expectedShelfLifeDays Int?          @map("expected_shelf_life_days")
  
  currentStatus         BatchStatus   @default(FRESH) @map("current_status")
  currentLocation       String?       @map("current_location")
  remarks               String?
  
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  farmer                Farmer        @relation(fields: [farmerId], references: [id])
  crop                  Crop          @relation(fields: [cropId], references: [id])
  fpo                   Fpo?          @relation(fields: [fpoId], references: [id])
  
  inventories           Inventory[]
  movements             Movement[]
  recommendations       Recommendation[]
  riskAssessments       RiskAssessment[]
  predictionSnapshots   PredictionSnapshot[]
  transportRequests     TransportRequest[]

  @@map("harvest_batches")
}

/// Stored inventory inside a warehouse
model Inventory {
  id                String       @id @default(uuid())
  batchId           String       @map("batch_id")
  warehouseId       String       @map("warehouse_id")
  
  storedQuantity    Float        @map("stored_quantity")
  remainingQuantity Float        @map("remaining_quantity")
  
  storageDate       DateTime     @default(now()) @map("storage_date")
  expiryDate        DateTime?    @map("expiry_date")
  
  temperature       Float?
  humidity          Float?
  storageCondition  String?      @map("storage_condition")
  
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  harvestBatch      HarvestBatch @relation(fields: [batchId], references: [id])
  warehouse         Warehouse    @relation(fields: [warehouseId], references: [id])

  @@map("inventories")
}

/// Historical tracker of produce movement across lifecycle
model Movement {
  id            String       @id @default(uuid())
  batchId       String       @map("batch_id")
  
  fromLocation  String?      @map("from_location")
  toLocation    String?      @map("to_location")
  movementType  MovementType @map("movement_type")
  
  movementDate  DateTime     @default(now()) @map("movement_date")
  transportCost Float?       @map("transport_cost")
  remarks       String?
  
  createdAt     DateTime     @default(now()) @map("created_at")

  harvestBatch  HarvestBatch @relation(fields: [batchId], references: [id])

  @@map("movements")
}

// --------------------------------------------------
// Phase 4: AI Decision Intelligence Engine
// --------------------------------------------------

/// Stores the final recommendation generated for a batch
model Recommendation {
  id                String               @id @default(uuid())
  batchId           String               @map("batch_id")
  
  recommendedAction RecommendationAction @map("recommended_action")
  reason            String
  confidenceScore   Float                @map("confidence_score")
  priority          PriorityLevel
  
  expectedProfit    Float?               @map("expected_profit")
  spoilageRiskScore Float?               @map("spoilage_risk_score")
  
  createdAt         DateTime             @default(now()) @map("created_at")

  harvestBatch      HarvestBatch         @relation(fields: [batchId], references: [id])
  decisionHistories DecisionHistory[]

  @@map("recommendations")
}

/// Logs how the engine evaluated all possible actions
model DecisionHistory {
  id                String               @id @default(uuid())
  recommendationId  String               @map("recommendation_id")
  
  actionEvaluated   RecommendationAction @map("action_evaluated")
  score             Float
  reasoning         String
  
  createdAt         DateTime             @default(now()) @map("created_at")

  recommendation    Recommendation       @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@map("decision_histories")
}

/// Granular risk assessment for a batch
model RiskAssessment {
  id              String       @id @default(uuid())
  batchId         String       @map("batch_id")
  
  riskScore       Float        @map("risk_score")
  riskCategory    RiskCategory @map("risk_category")
  factors         Json         // Storing { "remainingShelfLife": X, "storageQuality": Y }
  
  createdAt       DateTime     @default(now()) @map("created_at")

  harvestBatch    HarvestBatch @relation(fields: [batchId], references: [id])

  @@map("risk_assessments")
}

/// ML Readiness: Data snapshot at prediction time
model PredictionSnapshot {
  id                      String       @id @default(uuid())
  batchId                 String       @map("batch_id")
  
  shelfLifeRemaining      Float?       @map("shelf_life_remaining")
  storageQuality          String?      @map("storage_quality")
  environmentalConditions Json?        @map("environmental_conditions")
  
  createdAt               DateTime     @default(now()) @map("created_at")

  harvestBatch            HarvestBatch @relation(fields: [batchId], references: [id])

  @@map("prediction_snapshots")
}

// --------------------------------------------------
// Phase 5: Market Intelligence & Predictive Analytics
// --------------------------------------------------

enum DemandLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Historical market prices for crops at specific markets
model MarketPriceHistory {
  id              String   @id @default(uuid())
  marketId        String   @map("market_id")
  cropId          String   @map("crop_id")
  
  date            DateTime
  minPrice        Float    @map("min_price")
  maxPrice        Float    @map("max_price")
  modalPrice      Float    @map("modal_price")
  arrivalQuantity Float?   @map("arrival_quantity")
  
  createdAt       DateTime @default(now()) @map("created_at")

  market          Market   @relation(fields: [marketId], references: [id])
  crop            Crop     @relation(fields: [cropId], references: [id])

  @@unique([marketId, cropId, date])
  @@map("market_price_histories")
}

/// Future price predictions generated by the ML service
model PricePrediction {
  id                String   @id @default(uuid())
  marketId          String   @map("market_id")
  cropId            String   @map("crop_id")
  
  predictedDate     DateTime @map("predicted_date")
  predictedMinPrice Float    @map("predicted_min_price")
  predictedMaxPrice Float    @map("predicted_max_price")
  predictedModalPrice Float  @map("predicted_modal_price")
  confidenceScore   Float    @map("confidence_score")
  
  generatedAt       DateTime @default(now()) @map("generated_at")

  market            Market   @relation(fields: [marketId], references: [id])
  crop              Crop     @relation(fields: [cropId], references: [id])

  @@unique([marketId, cropId, predictedDate])
  @@map("price_predictions")
}

/// Market Demand index (computed periodically)
model MarketDemand {
  id              String      @id @default(uuid())
  marketId        String      @map("market_id")
  cropId          String      @map("crop_id")
  
  date            DateTime
  demandIndex     DemandLevel @map("demand_index")
  volatilityScore Float       @map("volatility_score")
  
  createdAt       DateTime    @default(now()) @map("created_at")

  market          Market      @relation(fields: [marketId], references: [id])
  crop            Crop        @relation(fields: [cropId], references: [id])

  @@unique([marketId, cropId, date])
  @@map("market_demands")
}

// --------------------------------------------------
// Phase 6: Logistics & Smart Distribution Intelligence
// --------------------------------------------------

enum VehicleType {
  TRUCK
  REFRIGERATED_TRUCK
  VAN
  PICKUP
}

enum TransportStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DELAYED
}

/// Vehicle Entity
model Vehicle {
  id              String      @id @default(uuid())
  registrationNo  String      @unique @map("registration_no")
  vehicleType     VehicleType @map("vehicle_type")
  capacity        Float       // in Metric Tons
  isAvailable     Boolean     @default(true) @map("is_available")
  currentLocation String?     @map("current_location")
  
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  drivers         Driver[]
  transportRequests TransportRequest[]
  
  @@map("vehicles")
}

/// Driver Entity
model Driver {
  id              String      @id @default(uuid())
  userId          String      @unique @map("user_id")
  licenseNumber   String      @unique @map("license_number")
  vehicleId       String?     @map("vehicle_id")
  isAvailable     Boolean     @default(true) @map("is_available")
  
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            User        @relation(fields: [userId], references: [id])
  vehicle         Vehicle?    @relation(fields: [vehicleId], references: [id])
  transportRequests TransportRequest[]

  @@map("drivers")
}

/// Transport Request for moving HarvestBatches
model TransportRequest {
  id                String          @id @default(uuid())
  batchId           String          @map("batch_id")
  vehicleId         String?         @map("vehicle_id")
  driverId          String?         @map("driver_id")
  
  pickupLocation    String          @map("pickup_location")
  dropoffLocation   String          @map("dropoff_location")
  
  status            TransportStatus @default(PENDING)
  scheduledDate     DateTime?       @map("scheduled_date")
  estimatedCost     Float?          @map("estimated_cost")
  
  distanceKm        Float?          @map("distance_km")
  estimatedTimeMins Int?            @map("estimated_time_mins")
  
  actualPickupTime  DateTime?       @map("actual_pickup_time")
  actualDeliveryTime DateTime?      @map("actual_delivery_time")
  
  fuelConsumed      Float?          @map("fuel_consumed")
  
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  harvestBatch      HarvestBatch    @relation(fields: [batchId], references: [id])
  vehicle           Vehicle?        @relation(fields: [vehicleId], references: [id])
  driver            Driver?         @relation(fields: [driverId], references: [id])
  coldChainLogs     ColdChainLog[]

  @@map("transport_requests")
}

/// Cold Chain IoT Data for Tracking
model ColdChainLog {
  id                 String           @id @default(uuid())
  transportRequestId String           @map("transport_request_id")
  timestamp          DateTime         @default(now())
  temperature        Float
  humidity           Float?
  latitude           Float?
  longitude          Float?

  transportRequest   TransportRequest @relation(fields: [transportRequestId], references: [id])

  @@map("cold_chain_logs")
}

