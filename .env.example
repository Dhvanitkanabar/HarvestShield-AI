# ==================================================
# HarvestShield AI - Environment Variables Template
# ==================================================

# Server
NODE_ENV=development
PORT=5000

# Database Configuration (Used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=harvestshield_db

# Prisma Database URL
# For native local usage: postgresql://postgres:postgres@localhost:5432/harvestshield_db?schema=public
# For Docker usage (internal network): postgresql://postgres:postgres@postgres:5432/harvestshield_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/harvestshield_db?schema=public"

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@harvestshield.ai
PGADMIN_DEFAULT_PASSWORD=admin123

# JWT
JWT_SECRET="harvestshield-dev-secret-change-in-production-2024"
JWT_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Cookie
COOKIE_SECRET="harvestshield-cookie-secret-change-in-production"
